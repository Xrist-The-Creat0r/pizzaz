{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/", "status": 308, "headers": { "Location": "/menu" } },
    { "src": "/menu",        "dest": "/menu/index.html" },
    { "src": "/menu/(.*)",   "dest": "/menu/$1" },
    { "src": "/admin",       "dest": "/admin/index.html" },
    { "src": "/admin/(.*)",  "dest": "/admin/$1" },
    { "src": "/shared/(.*)", "dest": "/shared/$1" },
    { "src": "/api/(.*)",    "dest": "/server.js" }
  ]
}
